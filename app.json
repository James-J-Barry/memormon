{
  "expo": {
    "name": "MemoryMon",
    "slug": "memormon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "memorymon",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f13"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.memorymon.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a482b24f-a262-486b-842e-bf47a522f8cc"
      }
    },
    "owner": "james-j-barry",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a482b24f-a262-486b-842e-bf47a522f8cc"
    },
    "android": {}
  }
}
